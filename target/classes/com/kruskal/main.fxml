<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kruskal.controller.MainController"
      spacing="10"
      style="-fx-padding: 10;">

    <VBox spacing="5">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="Add Node" onAction="#onAddNode"/>
            <Button text="Add Edge" onAction="#onAddEdge"/>
            <Button text="Edit Weight" onAction="#onEditWeight"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Save Graph" onAction="#onSaveGraph"/>
            <Button text="Insert Graph" onAction="#onInsertGraph"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="Delete Node" onAction="#onDeleteNode"/>
            <Button text="Delete Edge" onAction="#onDeleteEdge"/>
        </HBox>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Generate Graph" onAction="#onGenerateGraph"/>
        <Button text="Run Kruskal Auto" onAction="#onRunKruskalAuto"/>
        <Label text="speed (ms):"/>
        <TextField fx:id="speedTextField" prefWidth="80" text="2000"/>
        <Button text="Run Kruskal Manual" onAction="#onRunKruskalManual"/>
        <Button text="Prev Step" onAction="#onPrevStep"/>
        <Button text="Next Step" onAction="#onNextStep"/>
        <Button text="Clean" onAction="#onClean"/>
    </HBox>

    <HBox spacing="10" VBox.vgrow="ALWAYS">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Original Graph" style="-fx-font-weight: bold;"/>
            <Canvas fx:id="graphCanvas" width="400" height="500"
                    style="-fx-border-color: #cccccc; -fx-border-width: 2; -fx-border-radius: 5;"
                    VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="MST" style="-fx-font-weight: bold;"/>
            <Canvas fx:id="mstCanvas" width="400" height="500"
                    style="-fx-border-color: #cccccc; -fx-border-width: 2; -fx-border-radius: 5;"
                    VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Steps" style="-fx-font-weight: bold;"/>
            <TextArea fx:id="stepsTextArea" editable="false" wrapText="true"
                      style="-fx-border-color: #cccccc; -fx-border-width: 2; -fx-border-radius: 5; -fx-font-family: monospace;"
                      VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS"/>
        </VBox>
    </HBox>

    <HBox alignment="CENTER_LEFT">
        <Button text="Info" onAction="#onInfo"/>
    </HBox>
</VBox>